# Supabase — copy this file to `.env` and fill in your project values.
# Find both in the Supabase dashboard: Project Settings → API.
# These are the PUBLIC anon key + URL and are safe to ship in a client bundle.
# Expo inlines any EXPO_PUBLIC_* var at build time — restart `expo start` after editing.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
